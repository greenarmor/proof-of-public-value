# PoPV AI Oracle - Environment Variables
# Copy this to .env and fill in the values
# NEVER commit .env to git!
#
# On your VPS:
#   cp .env.example .env
#   nano .env    (fill in your actual secret keys)

# Required: AI Auditor wallet secret key (for submitting fraud/risk results on-chain)
AI_AUDITOR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: Admin secret key (for minting pPHP rewards to citizens)
ADMIN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: DeepSeek API key for LLM-powered fraud analysis
# Get a key from: https://platform.deepseek.com/api_keys
AI_LLM_API_KEY=sk-your-deepseek-key-here
AI_LLM_BASE_URL=https://api.deepseek.com/v1
AI_LLM_MODEL=deepseek-chat
