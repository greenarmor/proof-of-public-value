{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "es2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2023"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "sourceMap": false,
    "declaration": false,
    "removeComments": true
  },
  "include": ["server.ts"]
}
